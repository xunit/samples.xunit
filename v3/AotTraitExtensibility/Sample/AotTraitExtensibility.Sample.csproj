<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Uncomment this line to save the generated files to disk, can be helpful in debugging the generator -->
    <!--<EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>-->
    <Nullable>enable</Nullable>
    <OutputType>Exe</OutputType>
    <PublishAot>true</PublishAot>
    <TargetFramework>net9.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Extension\AotTraitExtensibility.Extension.csproj" />
    <ProjectReference Include="..\Generator\AotTraitExtensibility.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3.aot.mtp-v2" Version="$(Version_xunit_v3)" />
  </ItemGroup>

</Project>
